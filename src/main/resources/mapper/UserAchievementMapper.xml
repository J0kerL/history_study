<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 1. namespace 必须指向你的 Mapper 接口的全限定名 -->
<mapper namespace="com.history.mapper.UserAchievementMapper">

    <!-- 2. ResultMap: 处理数据库下划线与 Java 驼峰命名的映射 -->
    <resultMap id="BaseResultMap" type="com.history.model.entity.UserAchievement">
        <!-- id 标签用于主键 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        <!-- result 标签用于普通字段 -->
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="achievement_id" property="achievementId" jdbcType="INTEGER"/>
        <result column="unlocked_at" property="unlockedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 根据用户id查询用户成就列表 -->
    <select id="selectByUserId" resultType="com.history.model.entity.UserAchievement">
        SELECT *
        FROM t_user_achievement
        WHERE user_id = #{id}
        ORDER BY unlocked_at DESC
    </select>


</mapper>