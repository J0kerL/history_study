<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.history.mapper.UserMapper">
    <!--
        动态更新用户信息：只更新前端传入的非空字段（动态 SET）。
        参数说明：
          id  - 来自 @Param("id") 的用户主键
          dto - 来自 @Param("dto") 的 UpdateUserProfileDTO
    -->
    <update id="update">
        UPDATE t_user
        <set>
            <if test="dto.username != null and dto.username != ''">
                username = #{dto.username},
            </if>
            <if test="dto.phone != null and dto.phone != ''">
                phone = #{dto.phone},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!--
        更新用户头像地址，由 POST /user/avatar 接口调用。
        avatarUrl 为 OSS 返回的完整访问 URL。
    -->
    <update id="updateAvatar">
        UPDATE t_user
        SET avatar = #{avatarUrl}
        WHERE id = #{id}
    </update>
</mapper>