<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.history.mapper.EventMapper">

    <resultMap id="BaseResultMap" type="com.history.model.entity.Event">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="year" property="year"/>
        <result column="month" property="month"/>
        <result column="day" property="day"/>
        <result column="summary" property="summary"/>
        <result column="content" property="content"/>
        <result column="image_url" property="imageUrl"/>
        <result column="tags" property="tags"/>
        <result column="source" property="source"/>
    </resultMap>

    <resultMap id="EventSummaryResultMap" type="com.history.model.vo.EventSummaryVO">
        <id column="id" property="id"/>
        <result column="year" property="year"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="image_url" property="imageUrl"/>
    </resultMap>

    <select id="selectSummaryByMonthDay" resultMap="EventSummaryResultMap">
        SELECT id, year, title, summary, image_url
        FROM t_event
        WHERE month = #{month}
          AND day = #{day}
        ORDER BY year ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, title, year, month, day, summary, content, image_url, tags, source
        FROM t_event
        WHERE id = #{id}
    </select>

    <select id="selectRelatedSummaries" resultMap="EventSummaryResultMap">
        SELECT e.id, e.year, e.title, e.summary, e.image_url
        FROM t_event_relation er
        INNER JOIN t_event e ON e.id = er.related_id
        WHERE er.event_id = #{eventId}
        ORDER BY er.sort_order DESC, e.year ASC
    </select>

</mapper>
